<script>
var xthemeText = <?= json_encode($jsText, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
var xthemeThemes = <?= json_encode($themePayload, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
var xthemeThemeFields = <?= json_encode(xtheme_shareable_keys(), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

function XThemeSetStatus(message, isError) {
  var node = $('#xtheme-status');
  node.text(message || '');
  node.css('color', isError ? '#f87171' : '#86efac');
}

function XThemeSyncRange(id, suffix) {
  var value = $('#' + id).val();
  $('#' + id + '_value').text(value + suffix);
}

function XThemeNormalizeColorValue(value) {
  var input = String(value || '').trim().toLowerCase();
  if (/^#[0-9a-f]{8}$/.test(input)) {
    return input;
  }
  if (/^#[0-9a-f]{6}$/.test(input)) {
    return input + 'ff';
  }
  return '';
}

function XThemeColorValueToRgba(value) {
  var normalized = XThemeNormalizeColorValue(value);
  if (!normalized) {
    return 'rgba(255, 255, 255, 0)';
  }

  var red = parseInt(normalized.slice(1, 3), 16);
  var green = parseInt(normalized.slice(3, 5), 16);
  var blue = parseInt(normalized.slice(5, 7), 16);
  var alpha = Math.round((parseInt(normalized.slice(7, 9), 16) / 255) * 100) / 100;
  return 'rgba(' + red + ', ' + green + ', ' + blue + ', ' + alpha.toFixed(2) + ')';
}

function XThemeColorValueToText(value) {
  var normalized = XThemeNormalizeColorValue(value);
  if (!normalized) {
    return '#f8fafc';
  }

  var red = parseInt(normalized.slice(1, 3), 16);
  var green = parseInt(normalized.slice(3, 5), 16);
  var blue = parseInt(normalized.slice(5, 7), 16);
  var alpha = parseInt(normalized.slice(7, 9), 16) / 255;
  var base = 15;
  var mixedRed = red * alpha + base * (1 - alpha);
  var mixedGreen = green * alpha + base * (1 - alpha);
  var mixedBlue = blue * alpha + base * (1 - alpha);
  var luminance = (0.299 * mixedRed + 0.587 * mixedGreen + 0.114 * mixedBlue) / 255;
  return luminance > 0.68 ? '#08111d' : '#f8fafc';
}

function XThemeRefreshColorPreview(fieldId) {
  var input = $('#' + fieldId);
  if (!input.length) {
    return;
  }

  var normalized = XThemeNormalizeColorValue(input.val());
  if (normalized) {
    input.val(normalized);
  }

  var rgbaValue = XThemeColorValueToRgba(normalized || input.val());
  input.css('--xtheme-field-color', rgbaValue);
  input.css('--xtheme-field-text', XThemeColorValueToText(normalized || input.val()));
  input.attr('title', rgbaValue);
}

function XThemeRefreshRanges() {
  XThemeSyncRange('background_blur', 'px');
  XThemeSyncRange('glass_blur', 'px');
  XThemeSyncRange('overlay_opacity', '');
}

function XThemeThemeCanDelete(themeId) {
  var theme = xthemeThemes[themeId];
  return !!(theme && theme.can_delete);
}

function XThemeUpdateDeleteState(themeId) {
  var button = $('#xtheme-delete-theme');
  if (!button.length) {
    return;
  }

  var canDelete = XThemeThemeCanDelete(themeId);
  button.prop('disabled', !canDelete);
  button.attr('title', canDelete ? '' : xthemeText.delete_blocked);
}

function XThemeGetCsrfToken() {
  var inlineToken = $('#xtheme_upload_csrf').val();
  if (typeof inlineToken === 'string' && inlineToken.trim() !== '') {
    return inlineToken.trim();
  }

  if (typeof window.csrf_token === 'string' && window.csrf_token.trim() !== '') {
    return window.csrf_token.trim();
  }

  var tokenField = $('#xtheme-form input[name="csrf_token"]').first();
  if (!tokenField.length) {
    tokenField = $('input[name="csrf_token"]').first();
  }

  var token = tokenField.val();
  if (typeof token === 'string' && token.trim() !== '') {
    return token.trim();
  }

  return '';
}

function XThemeParseJsonResponse(responseText) {
  if (typeof responseText !== 'string') {
    return responseText;
  }

  var normalized = responseText.replace(/^\uFEFF/, '').trim();
  if (!normalized) {
    return null;
  }

  if (normalized.charAt(0) === '<') {
    return null;
  }

  return JSON.parse(normalized);
}

function XThemeApplyTheme(themeId) {
  var theme = xthemeThemes[themeId];
  if (!theme) {
    return;
  }

  $('#selected_theme_id').val(theme.id);
  $('#theme_select').val(theme.id);
  $('#theme_name').val(theme.name);

  xthemeThemeFields.forEach(function(field) {
    if (!Object.prototype.hasOwnProperty.call(theme, field)) {
      return;
    }

    var node = $('#' + field);
    if (!node.length) {
      return;
    }

    node.val(theme[field]);
    if (node.is('.xtheme-color-field')) {
      XThemeRefreshColorPreview(field);
    }
  });

  XThemeRefreshRanges();
  XThemeUpdateDeleteState(theme.id);
  XThemeSetStatus('', false);
}

function XThemeCollectThemePayload() {
  var payload = {
    selected_theme_id: $('#selected_theme_id').val(),
    theme_name: $('#theme_name').val()
  };

  xthemeThemeFields.forEach(function(field) {
    var node = $('#' + field);
    if (!node.length) {
      return;
    }
    payload[field] = node.val();
  });

  return payload;
}

function XThemeSaveTheme(mode) {
  var csrfToken = XThemeGetCsrfToken();
  if (!csrfToken) {
    XThemeSetStatus(xthemeText.upload_refresh, true);
    return;
  }

  var payload = XThemeCollectThemePayload();
  payload.mode = mode || 'save';
  payload.csrf_token = csrfToken;

  XThemeSetStatus(xthemeText.saving, false);

  $.ajax({
    url: '/plugins/xtheme/scripts/save_theme.php',
    method: 'POST',
    data: payload
  }).done(function(response) {
    var data = response;
    if (typeof data === 'string') {
      try {
        data = XThemeParseJsonResponse(data);
      } catch (error) {
        data = null;
      }
    }

    if (!data || !data.ok) {
      XThemeSetStatus((data && data.message) || xthemeText.upload_failed, true);
      return;
    }

    setTimeout(function() {
      var themeId = encodeURIComponent(data.theme_id || payload.selected_theme_id || '');
      location.href = '/Settings/XTheme?theme_id=' + themeId;
    }, 400);
  }).fail(function(xhr) {
    var message = xthemeText.upload_failed;
    if (xhr && xhr.responseText) {
      try {
        var data = XThemeParseJsonResponse(xhr.responseText);
        if (data && data.message) {
          message = data.message;
        }
      } catch (error) {
      }
    }
    XThemeSetStatus(message, true);
  });
}

function XThemeDeleteTheme() {
  var themeId = $('#selected_theme_id').val() || '';
  var theme = xthemeThemes[themeId];
  if (!theme || !XThemeThemeCanDelete(themeId)) {
    XThemeSetStatus(xthemeText.delete_blocked, true);
    return;
  }

  var csrfToken = XThemeGetCsrfToken();
  if (!csrfToken) {
    XThemeSetStatus(xthemeText.upload_refresh, true);
    return;
  }

  var themeName = $.trim($('#theme_name').val()) || theme.name || themeId;
  var confirmText = String(xthemeText.delete_confirm || '').replace('{name}', themeName);
  if (!window.confirm(confirmText)) {
    return;
  }

  XThemeSetStatus(xthemeText.deleting, false);

  $.ajax({
    url: '/plugins/xtheme/scripts/save_theme.php',
    method: 'POST',
    data: {
      mode: 'delete',
      selected_theme_id: themeId,
      csrf_token: csrfToken
    }
  }).done(function(response) {
    var data = response;
    if (typeof data === 'string') {
      try {
        data = XThemeParseJsonResponse(data);
      } catch (error) {
        data = null;
      }
    }

    if (!data || !data.ok) {
      XThemeSetStatus((data && data.message) || xthemeText.delete_failed, true);
      return;
    }

    XThemeSetStatus(data.message || xthemeText.deleted, false);
    setTimeout(function() {
      var nextThemeId = encodeURIComponent(data.theme_id || '');
      location.href = '/Settings/XTheme?theme_id=' + nextThemeId;
    }, 350);
  }).fail(function(xhr) {
    var message = xthemeText.delete_failed;
    if (xhr && xhr.responseText) {
      try {
        var data = XThemeParseJsonResponse(xhr.responseText);
        if (data && data.message) {
          message = data.message;
        }
      } catch (error) {
      }
    }
    XThemeSetStatus(message, true);
  });
}

function XThemeExportTheme() {
  var themeId = encodeURIComponent($('#selected_theme_id').val() || '');
  window.location.href = '/plugins/xtheme/scripts/export_theme.php?theme_id=' + themeId;
}

function XThemeImportTheme() {
  var input = $('#theme_archive')[0];
  if (!input.files || !input.files.length) {
    XThemeSetStatus(xthemeText.choose_theme_archive, true);
    return;
  }

  var file = input.files[0];
  var reader = new FileReader();
  XThemeSetStatus(xthemeText.importing, false);

  reader.onerror = function() {
    XThemeSetStatus(xthemeText.import_failed, true);
  };

  reader.onload = function() {
    var result = reader.result || '';
    if (typeof result !== 'string' || result.indexOf('base64,') === -1) {
      XThemeSetStatus(xthemeText.import_failed, true);
      return;
    }

    var csrfToken = XThemeGetCsrfToken();
    if (!csrfToken) {
      XThemeSetStatus(xthemeText.upload_refresh, true);
      return;
    }

    $.ajax({
      url: '/plugins/xtheme/scripts/import_theme.php',
      method: 'POST',
      data: {
        csrf_token: csrfToken,
        filename: file.name,
        content: result.split('base64,', 2)[1]
      }
    }).done(function(response, textStatus, xhr) {
      var data = response;
      if (typeof data === 'string') {
        try {
          data = XThemeParseJsonResponse(data);
        } catch (error) {
          data = null;
        }
      }

      if (!data) {
        XThemeSetStatus(xthemeText.import_failed, true);
        return;
      }

      if (!data.ok) {
        XThemeSetStatus(data.message || xthemeText.import_failed, true);
        return;
      }

      $('#theme_archive').val('');
      XThemeSetStatus(data.message || xthemeText.imported, false);
      setTimeout(function() {
        var themeId = encodeURIComponent(data.theme_id || '');
        location.href = '/Settings/XTheme?theme_id=' + themeId;
      }, 400);
    }).fail(function(xhr) {
      var message = xthemeText.import_failed;
      if (xhr && xhr.responseText) {
        try {
          var data = XThemeParseJsonResponse(xhr.responseText);
          if (data && data.message) {
            message = data.message;
          }
        } catch (error) {
        }
      }
      XThemeSetStatus(message, true);
    });
  };

  reader.readAsDataURL(file);
}

function XThemeUploadBackground() {
  var input = $('#background_file')[0];
  if (!input.files || !input.files.length) {
    XThemeSetStatus(xthemeText.choose_image, true);
    return;
  }

  var file = input.files[0];
  var reader = new FileReader();
  XThemeSetStatus(xthemeText.uploading, false);

  reader.onerror = function() {
    XThemeSetStatus(xthemeText.upload_unreadable, true);
  };

  reader.onload = function() {
    var result = reader.result || '';
    if (typeof result !== 'string' || result.indexOf('base64,') === -1) {
      XThemeSetStatus(xthemeText.upload_unreadable, true);
      return;
    }

    var csrfToken = XThemeGetCsrfToken();
    if (!csrfToken) {
      XThemeSetStatus(xthemeText.upload_refresh, true);
      return;
    }

    var payload = {
      csrf_token: csrfToken,
      selected_theme_id: $('#selected_theme_id').val() || '',
      filename: file.name,
      mime: file.type || 'application/octet-stream',
      content: result.split('base64,', 2)[1]
    };

    $.ajax({
      url: '/plugins/xtheme/scripts/upload_background.php',
      method: 'POST',
      data: payload
    }).done(function(response, textStatus, xhr) {
      var data = response;
      if (typeof data === 'string') {
        try {
          data = XThemeParseJsonResponse(data);
        } catch (error) {
          data = null;
        }
      }

      if (!data) {
        var responseType = '';
        if (xhr && typeof xhr.getResponseHeader === 'function') {
          responseType = xhr.getResponseHeader('Content-Type') || '';
        }
        if (/text\/html/i.test(responseType)) {
          XThemeSetStatus(xthemeText.upload_refresh, true);
        } else {
          XThemeSetStatus(xthemeText.upload_unreadable, true);
        }
        return;
      }

      if (!data.ok) {
        XThemeSetStatus(data.message || xthemeText.upload_failed, true);
        return;
      }

      $('#background_image').val(data.url);
      $('#background_file').val('');
      XThemeSetStatus(data.message || xthemeText.uploaded, false);
    }).fail(function(xhr) {
      var message = xthemeText.upload_failed;
      if (xhr && xhr.responseText) {
        try {
          var data = XThemeParseJsonResponse(xhr.responseText);
          if (data && data.message) {
            message = data.message;
          } else if (xhr.getResponseHeader && /text\/html/i.test(xhr.getResponseHeader('Content-Type') || '')) {
            message = xthemeText.upload_refresh;
          }
        } catch (error) {
        }
      }
      XThemeSetStatus(message, true);
    });
  };

  reader.readAsDataURL(file);
}

function XThemeClearBackground() {
  $('#background_image').val('');
  $('#background_file').val('');
  XThemeSetStatus(xthemeText.cleared, false);
}

$(function() {
  if (typeof Coloris === 'function') {
    Coloris({
      el: '.xtheme-color-field',
      alpha: true,
      forceAlpha: true,
      format: 'hex',
      wrap: false,
      themeMode: 'dark',
      clearButton: false,
      closeButton: true,
      closeLabel: xthemeText.picker_close,
      a11y: {
        open: xthemeText.picker_open,
        close: xthemeText.picker_close,
        input: xthemeText.picker_input,
        hueSlider: xthemeText.picker_hue,
        alphaSlider: xthemeText.picker_alpha
      }
    });
  }

  $('.xtheme-color-field').each(function() {
    XThemeRefreshColorPreview(this.id);
  }).on('input change', function() {
    XThemeRefreshColorPreview(this.id);
  });

  $('#theme_select').on('change', function() {
    XThemeApplyTheme($(this).val());
  });

  XThemeRefreshRanges();
  $('#background_blur,#glass_blur,#overlay_opacity').on('input change', XThemeRefreshRanges);
  XThemeApplyTheme($('#selected_theme_id').val());
});
</script>
