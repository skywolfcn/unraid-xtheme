<script>
var xthemeText = <?= json_encode($jsText, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

function XThemeSetStatus(message, isError) {
  var node = $('#xtheme-status');
  node.text(message || '');
  node.css('color', isError ? '#f87171' : '#86efac');
}

function XThemeSyncRange(id, suffix) {
  var value = $('#' + id).val();
  $('#' + id + '_value').text(value + suffix);
}

function XThemeRefreshRanges() {
  XThemeSyncRange('background_blur', 'px');
  XThemeSyncRange('glass_blur', 'px');
  XThemeSyncRange('overlay_opacity', '');
  XThemeSyncRange('panel_opacity', '');
  XThemeSyncRange('panel_border_opacity', '');
}

function XThemeAfterSave() {
  XThemeSetStatus(xthemeText.saving, false);
  setTimeout(function() {
    location.reload();
  }, 1200);
  return true;
}

function XThemeUploadBackground() {
  var input = $('#background_file')[0];
  if (!input.files || !input.files.length) {
    XThemeSetStatus(xthemeText.choose_image, true);
    return;
  }

  var file = input.files[0];
  var reader = new FileReader();
  XThemeSetStatus(xthemeText.uploading, false);

  reader.onerror = function() {
    XThemeSetStatus(xthemeText.upload_unreadable, true);
  };

  reader.onload = function() {
    var result = reader.result || '';
    if (typeof result !== 'string' || result.indexOf('base64,') === -1) {
      XThemeSetStatus(xthemeText.upload_unreadable, true);
      return;
    }

    var payload = new FormData();
    payload.append('csrf_token', csrf_token);
    payload.append('filename', file.name);
    payload.append('mime', file.type || 'application/octet-stream');
    payload.append('content', result.split('base64,', 2)[1]);

    $.ajax({
      url: '/plugins/xtheme/scripts/upload_background.php',
      method: 'POST',
      data: payload,
      processData: false,
      contentType: false
    }).done(function(response) {
      var data = response;
      if (typeof data === 'string') {
        try {
          data = JSON.parse(data);
        } catch (error) {
          XThemeSetStatus(xthemeText.upload_unreadable, true);
          return;
        }
      }

      if (!data.ok) {
        XThemeSetStatus(data.message || xthemeText.upload_failed, true);
        return;
      }

      $('#background_image').val(data.url);
      $('#background_file').val('');
      XThemeSetStatus(data.message || xthemeText.uploaded, false);
    }).fail(function(xhr) {
      var message = xthemeText.upload_failed;
      if (xhr && xhr.responseText) {
        try {
          var data = JSON.parse(xhr.responseText);
          message = data.message || message;
        } catch (error) {
        }
      }
      XThemeSetStatus(message, true);
    });
  };

  reader.readAsDataURL(file);
}

function XThemeClearBackground() {
  $('#background_image').val('');
  $('#background_file').val('');
  XThemeSetStatus(xthemeText.cleared, false);
}

$(function() {
  XThemeRefreshRanges();
  $('#background_blur,#glass_blur,#overlay_opacity,#panel_opacity,#panel_border_opacity').on('input change', XThemeRefreshRanges);
});
</script>
