<?xml version="1.0" standalone="yes"?>
<!DOCTYPE PLUGIN [
<!ENTITY name "xtheme">
<!ENTITY author "skywolf">
<!ENTITY version "2026.06.04.1">
<!ENTITY md5 "c4e12aedefd419c866c0bf6cffa45df3">
<!ENTITY pluginURL "file:///boot/config/plugins/xtheme/xtheme.plg">
]>
<PLUGIN name="&name;" author="&author;" version="&version;" pluginURL="&pluginURL;" icon="paint-brush" min="7.2.0" launch="Settings/XTheme">
<CHANGES>
###2026.06.04.1
- Initial release of a simplified glass theme plugin for Unraid 7.2.x
</CHANGES>
<FILE Run="/bin/bash">
<INLINE>
mkdir -p /boot/config/plugins/xtheme/packages
rm -f $(ls /boot/config/plugins/xtheme/xtheme*.txz 2&gt;/dev/null | grep -v '2026.06.04.1')
</INLINE>
</FILE>
<FILE Name="/boot/config/plugins/xtheme/packages/xtheme-2026.06.04.1-x86_64-1.txz" Run="upgradepkg --reinstall --install-new">
<LOCAL>/boot/config/plugins/xtheme/packages/xtheme-2026.06.04.1-x86_64-1.txz</LOCAL>
<MD5>&md5;</MD5>
</FILE>
<FILE Run="/bin/bash">
<INLINE><![CDATA[
plugin_url="file:///boot/config/plugins/xtheme/xtheme.plg"
case "$plugin_url" in
  file://*)
    cp -f "${plugin_url#file://}" /boot/config/plugins/xtheme.plg 2>/dev/null || true
    ;;
  http://*|https://*)
    wget -q -O /boot/config/plugins/xtheme.plg "$plugin_url" 2>/dev/null || true
    ;;
esac
rm -f /boot/config/plugins-error/xtheme.plg
mkdir -p /boot/config/plugins/xtheme/backgrounds
if [ ! -f /boot/config/plugins/xtheme/xtheme.cfg ]; then
  cp -f /usr/local/emhttp/plugins/xtheme/default.cfg /boot/config/plugins/xtheme/xtheme.cfg
fi
rm -rf /usr/local/emhttp/plugins/xtheme/backgrounds
ln -snf /boot/config/plugins/xtheme/backgrounds /usr/local/emhttp/plugins/xtheme/backgrounds
php /usr/local/emhttp/plugins/xtheme/scripts/login_hook_patch.php install >/dev/null 2>&1 || true
php /usr/local/emhttp/plugins/xtheme/scripts/refresh_login_theme.php >/dev/null 2>&1 || true
]]></INLINE>
</FILE>
<FILE Run="/bin/bash" Method="remove">
<INLINE><![CDATA[
php /usr/local/emhttp/plugins/xtheme/scripts/login_hook_patch.php remove >/dev/null 2>&1 || true
removepkg xtheme-2026.06.04.1-x86_64-1 2>/dev/null
rm -f /boot/config/plugins/xtheme.plg
rm -rf /usr/local/emhttp/plugins/xtheme
rm -rf /boot/config/plugins/xtheme
]]></INLINE>
</FILE>
</PLUGIN>